<section id="interest" class="interest">
  <div class="wrap">
    <div class="sec-head centered">
      <span class="eyebrow">// <span class="en">hackathon</span><span class="hu">hackathon</span></span>
      <h2><span class="en">Agent Control Deck Hackathon</span><span class="hu">Agent Control Deck Hackathon</span></h2>
      <p><span class="en">Teams build a physical interface for controlling AI agents — assign a task, show status, approve an action, hit stop. Identical kits provided: controller boards, mics, buttons, displays. Three hours, then demos.</span><span class="hu">Csapatok fizikai felületet építenek AI ágensek vezérlésére — feladat kiosztása, állapot kijelzése, jóváhagyás, leállítás. Azonos készletek: vezérlőpanelek, mikrofonok, gombok, kijelzők. Három óra, majd demók.</span></p>
    </div>

    <div class="interest-facts">
      <span>📅 <span class="en">End of August, weekday evening</span><span class="hu">Augusztus vége, hétköznap este</span></span>
      <span>⏱ <span class="en">3 hours of building</span><span class="hu">3 óra építés</span></span>
      <span>👥 <span class="en">24–32 builders in teams</span><span class="hu">24–32 építő csapatokban</span></span>
      <span>🍕 <span class="en">Kits, pizza &amp; drinks included</span><span class="hu">Készletek, pizza és ital</span></span>
    </div>

    <p class="interest-note"><span class="en">The date isn't locked yet. Leave your details and we'll mail you the moment it is — your date preference helps us pick it.</span><span class="hu">A dátum még nincs véglegesítve. Add meg az adataid, és szólunk, amint megvan — a preferenciád segít kiválasztani.</span></p>

    <form class="interest-form" id="interest-form" novalidate>
      <div class="if-row">
        <label class="if-field">
          <span class="if-label"><span class="en">Name</span><span class="hu">Név</span></span>
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label class="if-field">
          <span class="if-label"><span class="en">Email</span><span class="hu">E-mail</span></span>
          <input type="email" name="email" required autocomplete="email" />
        </label>
      </div>

      <div class="if-row">
        <label class="if-field">
          <span class="if-label"><span class="en">What do you build?</span><span class="hu">Mit építesz?</span></span>
          <select name="background">
            <option value="firmware" data-en="Firmware / embedded" data-hu="Firmware / beágyazott">Firmware / embedded</option>
            <option value="hardware" data-en="Hardware / PCB" data-hu="Hardver / NYÁK">Hardware / PCB</option>
            <option value="mechanical" data-en="Mechanical / CAD" data-hu="Gépész / CAD">Mechanical / CAD</option>
            <option value="software" data-en="Software / AI" data-hu="Szoftver / AI">Software / AI</option>
            <option value="curious" data-en="Curious beginner" data-hu="Érdeklődő kezdő">Curious beginner</option>
          </select>
        </label>
        <label class="if-field">
          <span class="if-label"><span class="en">Coming as</span><span class="hu">Így jönnék</span></span>
          <select name="team">
            <option value="solo" data-en="Solo — match me with a team" data-hu="Egyedül — párosítsatok csapattal">Solo — match me with a team</option>
            <option value="team" data-en="I have a team" data-hu="Van csapatom">I have a team</option>
            <option value="unsure" data-en="Not sure yet" data-hu="Még nem tudom">Not sure yet</option>
          </select>
        </label>
      </div>

      <fieldset class="if-field if-dates">
        <legend class="if-label"><span class="en">Which evenings could work? (pick any)</span><span class="hu">Mely esték jók? (több is választható)</span></legend>
        <div class="if-checks">
          <label><input type="checkbox" name="dates" value="aug-week-3" /> <span class="en">Aug 18–22</span><span class="hu">Aug. 18–22.</span></label>
          <label><input type="checkbox" name="dates" value="aug-week-4" /> <span class="en">Aug 25–29</span><span class="hu">Aug. 25–29.</span></label>
          <label><input type="checkbox" name="dates" value="sep-week-1" /> <span class="en">Sep 1–5</span><span class="hu">Szept. 1–5.</span></label>
          <label><input type="checkbox" name="dates" value="any" /> <span class="en">Any of them</span><span class="hu">Bármelyik</span></label>
        </div>
      </fieldset>

      <label class="if-field">
        <span class="if-label"><span class="en">Anything else? (optional)</span><span class="hu">Bármi más? (opcionális)</span></span>
        <textarea name="notes" rows="2"></textarea>
      </label>

      <input type="text" name="company_website" class="if-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div class="if-actions">
        <button class="btn primary" type="submit" id="if-submit"><span class="en">Register interest</span><span class="hu">Érdeklődés jelzése</span></button>
        <span class="if-privacy"><span class="en">We'll only email you about this hackathon.</span><span class="hu">Csak erről a hackathonról írunk.</span></span>
      </div>

      <p class="if-msg" id="if-msg" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<script is:inline>
  (function () {
    var form = document.getElementById('interest-form');
    if (!form) return;
    var msg = document.getElementById('if-msg');
    var btn = document.getElementById('if-submit');

    function t(en, hu) {
      return document.documentElement.getAttribute('data-lang') === 'hu' ? hu : en;
    }

    // <option> can't hold the .en/.hu spans the rest of the site uses, so mirror
    // the language toggle onto option text via data-en / data-hu.
    var options = form.querySelectorAll('option[data-en]');
    function syncOptionLang() {
      var hu = document.documentElement.getAttribute('data-lang') === 'hu';
      for (var i = 0; i < options.length; i++) {
        options[i].textContent = options[i].getAttribute(hu ? 'data-hu' : 'data-en');
      }
    }
    syncOptionLang();
    new MutationObserver(syncOptionLang).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-lang']
    });

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (!form.reportValidity()) return;

      var fd = new FormData(form);
      var payload = {
        name: (fd.get('name') || '').trim(),
        email: (fd.get('email') || '').trim(),
        background: fd.get('background') || '',
        team: fd.get('team') || '',
        dates: fd.getAll('dates'),
        notes: (fd.get('notes') || '').trim(),
        company_website: fd.get('company_website') || ''
      };

      btn.disabled = true;
      msg.className = 'if-msg';
      msg.textContent = t('Sending…', 'Küldés…');

      fetch('/api/interest', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(function (r) {
          if (!r.ok) throw new Error('http ' + r.status);
          form.querySelector('.if-row').scrollIntoView({ behavior: 'smooth', block: 'center' });
          form.reset();
          msg.className = 'if-msg ok';
          msg.textContent = t(
            "You're on the list. We'll email you as soon as the date is locked.",
            'Felkerültél a listára. Írunk, amint megvan a dátum.'
          );
        })
        .catch(function () {
          msg.className = 'if-msg err';
          msg.innerHTML = t(
            'Something broke on our side. Mail us at <a href="mailto:hello@bhw.hu">hello@bhw.hu</a> instead.',
            'Hiba történt nálunk. Írj inkább a <a href="mailto:hello@bhw.hu">hello@bhw.hu</a> címre.'
          );
        })
        .finally(function () {
          btn.disabled = false;
        });
    });
  })();
</script>

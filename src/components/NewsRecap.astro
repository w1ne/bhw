---
import { getEntry, render } from 'astro:content';

const post = await getEntry('news', 'meetup-1-build-before-the-hardware-arrives');
const { Content } = await render(post);
---

<section id="news"><div class="wrap"><div class="sec-head"><span class="eyebrow">// <span class="en">news</span><span class="hu">hírek</span></span><h2><span class="en">From the club</span><span class="hu">A klubból</span></h2><p><span class="en">Notes, recaps and what we learned together.</span><span class="hu">Jegyzetek, összefoglalók és közös tanulságok.</span></p></div><article class="recap"><div class="recap-copy"><span class="badge"><span class="en">{post.data.badge}</span><span class="hu">{post.data.badgeHu}</span></span><h3><span class="en">{post.data.title}</span><span class="hu">{post.data.titleHu}</span></h3><Content /></div></article></div></section>

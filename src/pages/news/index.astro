---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import Navigation from '../../components/Navigation.astro';

const posts = (await getCollection('news')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="News · Budapest Hardware Club">
  <Navigation />
  <main class="news-page"><section><div class="wrap"><div class="sec-head"><span class="eyebrow">// <span class="en">news</span><span class="hu">hírek</span></span><h1><span class="en">From the club</span><span class="hu">A klubból</span></h1><p><span class="en">A written recap of every meetup: the topics we covered, the failures we took apart, and the practical takeaways. Missed one, or want the notes in writing? Start here.</span><span class="hu">Írásos összefoglaló minden találkozóról: az érintett témák, a szétszedett hibák és a gyakorlati tanulságok. Lemaradtál, vagy írásban kellenek a jegyzetek? Kezdd itt.</span></p></div><div class="news-grid">{posts.map((post) => (<article class="news-card"><span class="badge"><span class="en">{post.data.badge}</span><span class="hu">{post.data.badgeHu}</span></span><h2><a href={`/news/${post.slug}/`}><span class="en">{post.data.title}</span><span class="hu">{post.data.titleHu}</span></a></h2><p><span class="en">{post.data.description}</span><span class="hu">{post.data.descriptionHu}</span></p><a class="readmore" href={`/news/${post.slug}/`}><span class="en">Read the article →</span><span class="hu">Cikk megnyitása →</span></a></article>))}</div></div></section></main>
  <Footer />
</BaseLayout>
